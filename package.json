{
  "name": "edex",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "tauri build",
    "build-debug": "tauri build --debug",
    "dev": "tauri dev",
    "lint": "biome check --write . && cargo fmt --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "prepare": "husky",
    "tauri": "tauri",
    "type-check": "tsc --pretty --noEmit",
    "vite-build": "tsc && vite build",
    "vite-dev": "vite"
  },
  "dependencies": {
    "@solid-primitives/date": "2.1.6",
    "@solid-primitives/keyboard": "1.3.5",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/solid-query": "5.100.9",
    "@tanstack/solid-table": "8.21.3",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-log": "2.8.0",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-store": "2.4.3",
    "@xterm/addon-clipboard": "0.2.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "augmented-ui": "2.0.0",
    "clsx": "2.1.1",
    "pretty-bytes": "7.1.0",
    "smoothie": "1.36.1",
    "solid-js": "1.9.12",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tanstack/solid-query-devtools": "5.100.9",
    "@tauri-apps/cli": "2.11.1",
    "@types/node": "24.12.3",
    "husky": "9.1.7",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-plugin-solid": "2.11.12"
  }
}
